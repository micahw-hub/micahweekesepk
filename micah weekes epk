<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MICAH WEEKES — EPK 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --black: #000000;
            --white: #FFFFFF;
            --gray-100: #F5F5F5;
            --gray-200: #E5E5E5;
            --gray-400: #A3A3A4;
            --gray-600: #525252;
            --gray-800: #262626;
            --font-primary: 'Helvetica Neue', 'Helvetica', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-display: 'Helvetica Neue', 'Helvetica', 'Inter', sans-serif;
            --font-mono: 'Courier New', monospace;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; font-size: 16px; }

        body {
            font-family: var(--font-primary);
            background-color: var(--white);
            color: var(--black);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        img {
            max-width: 100%;
            display: block;
        }

        a {
            color: inherit;
            text-decoration: none;
            border-bottom: 1px solid var(--black);
            transition: opacity 0.2s ease;
        }
        a:hover { opacity: 0.5; }

        .container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* ============================================
           HEADER
           ============================================ */
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            background: var(--white);
            border-bottom: 1px solid var(--black);
        }
        .site-header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 48px;
        }
        .nav-links {
            display: flex;
            gap: 32px;
        }
        .nav-links a {
            border-bottom: none;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ============================================
           HERO — LANDSCAPE COVER SHOT + ARTIST NAME
           ============================================ */
        .hero {
            padding-top: 48px;
            background: var(--white);
        }

        .hero-cover {
            width: 100%;
            aspect-ratio: 16 / 7;
            object-fit: cover;
            display: block;
        }

        .hero-bottom-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding: 24px 0;
            border-bottom: 1px solid var(--black);
        }

        .hero-name {
            font-size: clamp(48px, 10vw, 140px);
            line-height: 0.9;
            font-weight: 400;
            letter-spacing: -0.05em;
            text-transform: uppercase;
        }

        .hero-meta-right {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            line-height: 2;
            opacity: 0.5;
            text-align: right;
        }

        /* ============================================
           MEDIA STRIP — VIDEO + AUDIO
           ============================================ */
        .media-strip {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2px;
            background: var(--black);
            border-bottom: 1px solid var(--black);
        }

        .media-video {
            background: var(--black);
            position: relative;
            aspect-ratio: 16 / 9;
        }

        .media-video iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }

        .media-audio {
            background: var(--white);
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 100%;
        }

        .audio-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            opacity: 0.5;
        }

        .audio-title {
            font-size: clamp(24px, 3vw, 40px);
            line-height: 1.1;
            font-weight: 400;
            letter-spacing: -0.02em;
            margin-top: auto;
            margin-bottom: 24px;
        }

        /* ============================================
           SECTION HEADERS
           ============================================ */
        .section-header {
            border-bottom: 1px solid var(--black);
            padding: 16px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .section-num {
            font-size: 12px;
            font-weight: 300;
            opacity: 0.5;
        }
        .section-title {
            font-size: clamp(36px, 5vw, 64px);
            line-height: 1;
            font-weight: 400;
            letter-spacing: -0.03em;
            text-transform: uppercase;
        }

        /* ============================================
           01. INTRODUCTION
           ============================================ */
        .intro {
            padding: 64px 0 128px;
        }
        .intro-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
            padding-top: 64px;
        }
        .intro-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.5;
            margin-bottom: 32px;
        }
        .intro-body {
            font-size: 16px;
            line-height: 1.7;
            font-weight: 300;
            max-width: 540px;
        }
        .intro-body p { margin-bottom: 24px; }
        .intro-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
            margin-top: 64px;
            padding-top: 32px;
            border-top: 1px solid var(--black);
        }
        .stat-item {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .stat-value {
            font-size: 32px;
            font-weight: 400;
            letter-spacing: -0.02em;
        }
        .stat-label {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.5;
        }

        /* ============================================
           02. BIO
           ============================================ */
        .bio {
            padding: 0 0 128px;
        }
        .bio-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 64px;
            padding-top: 64px;
        }
        .bio-sidebar {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.5;
            line-height: 2;
        }
        .bio-body {
            font-size: 18px;
            line-height: 1.7;
            font-weight: 300;
            max-width: 700px;
        }
        .bio-body p { margin-bottom: 28px; }

        /* ============================================
           03. VIDEOS
           ============================================ */
        .videos {
            padding: 0 0 128px;
        }
        .videos-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 2px;
            background: var(--black);
            margin-top: 2px;
        }
        .video-card {
            background: var(--white);
            padding: 48px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .video-embed {
            width: 100%;
            aspect-ratio: 16 / 9;
            background: var(--gray-100);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .video-embed iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }
        .video-embed-placeholder {
            color: var(--black);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.5;
            text-align: center;
            line-height: 2;
        }
        .video-title {
            font-size: 24px;
            font-weight: 400;
            letter-spacing: -0.02em;
        }

        /* ============================================
           04. SOCIAL / CONTACT
           ============================================ */
        .social {
            background: var(--black);
            color: var(--white);
            padding: 128px 0;
        }
        .social-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 96px;
        }
        .social-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            opacity: 0.5;
            margin-bottom: 32px;
        }
        .social-info {
            font-size: 24px;
            line-height: 1.5;
            font-weight: 300;
        }
        .social-info a {
            color: var(--white);
            border-bottom: 1px solid rgba(255,255,255,0.3);
            display: inline-block;
            margin-bottom: 8px;
        }
        .social-info a:hover {
            border-bottom-color: var(--white);
        }
        .social-links {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 48px;
        }
        .social-links a {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            padding-bottom: 8px;
            display: flex;
            justify-content: space-between;
        }
        .social-links a:hover {
            border-bottom-color: var(--white);
        }

        /* ============================================
           FOOTER
           ============================================ */
        .site-footer {
            border-top: 1px solid rgba(255,255,255,0.15);
            padding: 24px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            opacity: 0.4;
        }

        /* ============================================
           RESPONSIVE
           ============================================ */
        @media (max-width: 900px) {
            .media-strip { grid-template-columns: 1fr; }
            .media-video { aspect-ratio: 16 / 9; }
            .intro-grid,
            .bio-grid,
            .social-grid {
                grid-template-columns: 1fr;
                gap: 48px;
            }
            .videos-grid {
                grid-template-columns: 1fr;
            }
            .intro-stats { grid-template-columns: 1fr; }
            .hero-name { font-size: clamp(36px, 12vw, 80px); }
        }

        @media (max-width: 600px) {
            .nav-links { display: none; }
            .container { padding: 0 16px; }
            .video-card { padding: 32px 24px; }
            .media-audio { padding: 32px 24px; }
        }
    </style>
</head>
